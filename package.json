{
	"name": "zenvy",
	"version": "1.0.0",
	"description": "A WordPress plugin with a custom post type, meta fields, shortcode, and REST API settings.",
	"author": "Rabindra Tharu",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"plugin"
	],
	"homepage": "https://www.linkedin.com/in/rabindratharu/",
	"repository": {
		"type": "git",
		"url": "https://github.com/rabindratharu/zenvy.git"
	},
	"bugs": {
		"url": "https://github.com/rabindratharu/zenvy/issues"
	},
	"main": "Gruntfile.js",
	"private": true,
	"dependencies": {
		"@wordpress/api-fetch": "^7.37.0",
		"@wordpress/components": "^31.0.0",
		"@wordpress/element": "^6.37.0",
		"@wordpress/i18n": "^6.10.0",
		"@wordpress/icons": "^11.4.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@babel/core": "^7.28.5",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/react": "^18.3.27",
		"@types/react-dom": "^18.3.7",
		"@wordpress/babel-preset-default": "^8.37.0",
		"@wordpress/browserslist-config": "^6.37.0",
		"@wordpress/env": "^10.37.0",
		"@wordpress/eslint-plugin": "^23.0.0",
		"@wordpress/scripts": "^31.2.0",
		"browserslist": "^4.28.1",
		"copy-webpack-plugin": "^13.0.1",
		"cross-env": "^10.1.0",
		"css-minimizer-webpack-plugin": "^7.0.4",
		"cypress": "^13.6.0",
		"dotenv": "^17.2.3",
		"eslint": "^8.57.1",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-import": "^2.32.0",
		"globals": "^16.5.0",
		"grunt": "^1.5.3",
		"grunt-checktextdomain": "^1.0.1",
		"grunt-contrib-clean": "^2.0.1",
		"grunt-contrib-compress": "^2.0.0",
		"grunt-contrib-copy": "^1.0.0",
		"grunt-wp-i18n": "^1.0.4",
		"load-grunt-tasks": "^5.1.0",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.6",
		"postcss-loader": "^8.2.0",
		"rimraf": "^6.1.2",
		"tailwindcss": "^4.1.16",
		"typescript": "^5.9.3",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"scripts": {
		"clean": "rimraf assets/build",
		"update": "wp-scripts packages-update",
		"rename": "bin/init.js",
		"cypress:open": "node_modules/.bin/cypress open",
		"build:dev": "cross-env NODE_ENV=development npm-run-all 'build:!(dev|prod)'",
		"build:js": "wp-scripts build --config ./webpack.config.js",
		"build:prod": "npm run clean && cross-env NODE_ENV=production npm-run-all 'build:!(dev|prod)' && composer install --no-dev --optimize-autoloader",
		"i18n:make-pot": "wp i18n make-pot . languages/zenvy.pot --include=\"assets/src/**/*.js,*.php,inc/**/*.php\" --exclude=\"assets/src/library/**,builds/,node_modules/,cypress/,vendor/,tests/,build/\" --ignore-domain --allow-root",
		"lint:css": "wp-scripts lint-style",
		"lint:css:fix": "npm run lint:css -- --fix",
		"lint:js:fix": "npm run lint:js -- --fix",
		"lint:js": "wp-scripts lint-js",
		"lint:js:types": "tsc --noEmit",
		"lint:php:fix": "composer run-script format",
		"lint:php:stan": "composer run-script phpstan",
		"lint:php": "composer run-script lint",
		"lint": "npm-run-all --parallel lint:*",
		"start:js": "wp-scripts start --config ./webpack.config.js",
		"start": "npm-run-all --parallel clean start:*",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ composer run-script test",
		"wp-env": "wp-env"
	},
	"overrides": {
		"@babel/runtime": "^7.27.6",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"webpack-dev-server@<=5.2.0": ">=5.2.1"
	}
}
